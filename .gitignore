# ============================================================================
# BVID-FE .gitignore
# ============================================================================

# ---- Python ----
__pycache__/
*.py[cod]
*$py.class
*.egg-info/
*.egg
dist/
build/
.eggs/
MANIFEST
*.so
*.dylib
*.pyd

# Streamlit local cache
.streamlit/secrets.toml

# ---- Virtual environments ----
venv/
.venv/
env/
ENV/
.virtualenv/

# ---- Type checker / linter caches ----
.mypy_cache/
.ruff_cache/
.pytype/
.dmypy.json
dmypy.json
.pyre/

# ---- Test / coverage caches ----
.pytest_cache/
.hypothesis/
.coverage
.coverage.*
coverage.xml
cov.xml
htmlcov/
.tox/
.nox/
nosetests.xml

# ---- Profiling output ----
*.prof
*.lprof

# ---- Jupyter ----
.ipynb_checkpoints/
*.ipynb_checkpoints
profile_default/
ipython_config.py

# ---- IDE / editor ----
.vscode/
.idea/
*.swp
*.swo
*~
*.sublime-workspace
*.sublime-project
.spyderproject
.spyproject
.ropeproject

# ---- OS ----
.DS_Store
Thumbs.db
ehthumbs.db
Desktop.ini
$RECYCLE.BIN/

# ---- Environment / secrets (NEVER commit) ----
.env
.env.local
.env.*.local
*.key
*.pem
*.p12
*.pfx
secrets.json
credentials.json

# ---- direnv / pyenv / asdf ----
.direnv/
.envrc
.python-version
.tool-versions

# ---- Merge conflict leftovers ----
*.orig
*.rej

# ---- Generic scratch / WIP (your personal files — not shared) ----
scratch/
_scratch/
wip/
tmp/
.tmp/
*.bak
*.backup
*.tmp
*.log

# Personal session notes (overnight, scratch, draft work)
OVERNIGHT_NOTES.md
*_NOTES.md
notes.md
notes_*.md
SCRATCH*.md
DRAFT*.md
TODO.md

# ---- BVID-FE-specific generated content (regenerated by scripts) ----
validation/figures/*.png
screenshots/*.png
examples/output/*.png
examples/output/*.csv
examples/output/*.json

# Local MkDocs build output (CI rebuilds and deploys to GitHub Pages).
site/

# ---- Claude Code / superpowers / subagent outputs ----
docs/superpowers/
.superpowers/
CLAUDE.md
.claude/
.anthropic/

# Shared Claude Code config: track the SessionStart hook and its settings so
# all sessions (web and local) pick up the same formatter-drift check.
!.claude/
.claude/*
!.claude/settings.json
!.claude/hooks/
!.claude/hooks/*
!.claude/skills/
!.claude/skills/**
